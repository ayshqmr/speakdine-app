rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Menu, logos, covers, avatars — owner-only writes; public reads for app URLs in Firestore
    match /user_uploads/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
